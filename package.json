{
  "name": "agentwerke-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop BPMN editor for Agentwerke workflows",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "desktop": "npm run build && electron .",
    "typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run",
    "build": "npm run typecheck && vite build && tsc -p tsconfig.electron.json",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac --publish never",
    "package:mac:unsigned": "npm run build && electron-builder --mac --publish never -c.mac.identity=null -c.mac.notarize=false",
    "package:mac:signed": "node scripts/validateMacReleaseEnv.mjs && npm run build && electron-builder --mac --publish never -c.forceCodeSigning=true",
    "package:win": "npm run build && electron-builder --win --publish never"
  },
  "dependencies": {
    "@bpmn-io/cm-theme": "^0.2.2",
    "@bpmn-io/properties-panel": "^3.44.1",
    "bpmn-auto-layout": "^1.3.0",
    "bpmn-js": "^17.11.1",
    "bpmn-js-properties-panel": "^5.58.0",
    "htm": "^3.1.1",
    "preact": "^10.29.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8",
    "jsdom": "24.1.0",
    "typescript": "^5.2.2",
    "vite": "^5.1.0",
    "vitest": "3.2.6",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "dev.agentwerke.desktop",
    "productName": "Agentwerke Desktop",
    "icon": "build/icon.png",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": true
    },
    "dmg": {
      "sign": false
    },
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": "AppImage",
      "category": "Development"
    }
  }
}
